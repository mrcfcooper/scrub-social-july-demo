{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tgn.local/schemas/ux/ux-pending-decision-item.schema.json",
  "title": "TGN UX Pending Decision Item",
  "type": "object",
  "required": [
    "schema",
    "itemType",
    "id",
    "title",
    "mode",
    "status",
    "authority",
    "confidence",
    "owner",
    "scope",
    "decision",
    "recommendation",
    "confirmation",
    "relationships",
    "confirmationBaseline"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "type": "string",
      "const": "tgn.ux-pending-decision.v1"
    },
    "itemType": {
      "type": "string",
      "const": "uxPendingDecision"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "$ref": "shared-definitions.schema.json#/$defs/mode"
    },
    "status": {
      "$ref": "shared-definitions.schema.json#/$defs/status"
    },
    "authority": {
      "$ref": "shared-definitions.schema.json#/$defs/authority"
    },
    "confidence": {
      "$ref": "shared-definitions.schema.json#/$defs/confidence"
    },
    "owner": {
      "$ref": "shared-definitions.schema.json#/$defs/owner"
    },
    "scope": {
      "$ref": "shared-definitions.schema.json#/$defs/scope"
    },
    "decision": {
      "type": "object",
      "required": [
        "question",
        "whyItMatters",
        "decisionNeededBy",
        "blockedBehavior",
        "options",
        "consequencesIfUnresolved"
      ],
      "additionalProperties": false,
      "properties": {
        "question": {
          "type": "string",
          "minLength": 1
        },
        "whyItMatters": {
          "type": "string",
          "minLength": 1
        },
        "decisionNeededBy": {
          "type": "string",
          "minLength": 1
        },
        "blockedBehavior": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "options": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "summary",
              "tradeoffsMd"
            ],
            "additionalProperties": false,
            "properties": {
              "id": {
                "type": "string"
              },
              "summary": {
                "type": "string"
              },
              "tradeoffsMd": {
                "type": "string"
              }
            }
          }
        },
        "consequencesIfUnresolved": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "recommendation": {
      "$ref": "shared-definitions.schema.json#/$defs/recommendation"
    },
    "confirmation": {
      "$ref": "shared-definitions.schema.json#/$defs/confirmation"
    },
    "relationships": {
      "type": "object",
      "required": [
        "affectedRequirementIds",
        "affectedMappingIds"
      ],
      "additionalProperties": false,
      "properties": {
        "affectedRequirementIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "affectedMappingIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "affectedFlowIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "generatedRefs": {
      "type": "object",
      "additionalProperties": true
    },
    "db": {
      "type": "object",
      "additionalProperties": true
    },
    "custom": {
      "$ref": "shared-definitions.schema.json#/$defs/custom"
    },
    "confirmationBaseline": {
      "$ref": "shared-definitions.schema.json#/$defs/confirmationBaseline"
    }
  }
}
