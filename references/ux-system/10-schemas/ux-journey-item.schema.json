{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tgn.local/schemas/ux/ux-journey-item.schema.json",
  "title": "TGN UX Journey Item",
  "type": "object",
  "required": [
    "schema",
    "itemType",
    "id",
    "title",
    "mode",
    "status",
    "authority",
    "confidence",
    "owner",
    "scope",
    "journey",
    "relationships",
    "confirmationBaseline"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "type": "string",
      "const": "tgn.ux-journey.v1"
    },
    "itemType": {
      "type": "string",
      "const": "uxJourney"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "$ref": "shared-definitions.schema.json#/$defs/mode"
    },
    "status": {
      "$ref": "shared-definitions.schema.json#/$defs/status"
    },
    "authority": {
      "$ref": "shared-definitions.schema.json#/$defs/authority"
    },
    "confidence": {
      "$ref": "shared-definitions.schema.json#/$defs/confidence"
    },
    "owner": {
      "$ref": "shared-definitions.schema.json#/$defs/owner"
    },
    "scope": {
      "$ref": "shared-definitions.schema.json#/$defs/scope"
    },
    "journey": {
      "type": "object",
      "required": [
        "userGoal",
        "userContext",
        "trigger",
        "startingState",
        "successOutcome",
        "happyPath",
        "alternatePaths",
        "hesitationOrFailurePoints",
        "recoveryExpectations",
        "nonGoals"
      ],
      "additionalProperties": false,
      "properties": {
        "userGoal": {
          "type": "string",
          "minLength": 1
        },
        "userContext": {
          "type": "string",
          "minLength": 1
        },
        "trigger": {
          "type": "string",
          "minLength": 1
        },
        "startingState": {
          "type": "string",
          "minLength": 1
        },
        "successOutcome": {
          "type": "string",
          "minLength": 1
        },
        "happyPath": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "alternatePaths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "hesitationOrFailurePoints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recoveryExpectations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "nonGoals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "relationships": {
      "type": "object",
      "required": [
        "featureIds",
        "subfeatureIds",
        "flowIds",
        "requirementIds"
      ],
      "additionalProperties": false,
      "properties": {
        "featureIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "subfeatureIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "flowIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "requirementIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "openQuestions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "generatedRefs": {
      "type": "object",
      "additionalProperties": true
    },
    "db": {
      "type": "object",
      "additionalProperties": true
    },
    "custom": {
      "$ref": "shared-definitions.schema.json#/$defs/custom"
    },
    "confirmationBaseline": {
      "$ref": "shared-definitions.schema.json#/$defs/confirmationBaseline"
    },
    "uxQualityAssessment": {
      "$ref": "shared-definitions.schema.json#/$defs/uxQualityAssessment"
    },
    "runtimeAlignment": {
      "$ref": "shared-definitions.schema.json#/$defs/runtimeAlignment"
    },
    "behaviorRelations": {
      "$ref": "shared-definitions.schema.json#/$defs/behaviorRelations"
    }
  }
}
