{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tgn.local/schemas/ux/ux-feature-item.schema.json",
  "title": "TGN UX Feature Item",
  "type": "object",
  "required": [
    "schema",
    "itemType",
    "id",
    "title",
    "mode",
    "status",
    "authority",
    "confidence",
    "owner",
    "scope",
    "feature",
    "relationships",
    "confirmationBaseline"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "type": "string",
      "const": "tgn.ux-feature.v1"
    },
    "itemType": {
      "type": "string",
      "const": "uxFeature"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "$ref": "shared-definitions.schema.json#/$defs/mode"
    },
    "status": {
      "$ref": "shared-definitions.schema.json#/$defs/status"
    },
    "authority": {
      "$ref": "shared-definitions.schema.json#/$defs/authority"
    },
    "confidence": {
      "$ref": "shared-definitions.schema.json#/$defs/confidence"
    },
    "owner": {
      "$ref": "shared-definitions.schema.json#/$defs/owner"
    },
    "scope": {
      "$ref": "shared-definitions.schema.json#/$defs/scope"
    },
    "feature": {
      "type": "object",
      "required": [
        "purpose",
        "userValue",
        "primaryUserGoals",
        "includedSubfeatures",
        "excludedBehavior",
        "primarySurfaces",
        "entryPoints",
        "exitPoints",
        "successOutcomes",
        "failureOrHesitationPoints",
        "recoveryExpectations",
        "importantConstraints",
        "nonGoals"
      ],
      "additionalProperties": false,
      "properties": {
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "userValue": {
          "type": "string",
          "minLength": 1
        },
        "primaryUserGoals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "includedSubfeatures": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "excludedBehavior": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "primarySurfaces": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "entryPoints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "exitPoints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "successOutcomes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "failureOrHesitationPoints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recoveryExpectations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "importantConstraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "nonGoals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "relationships": {
      "type": "object",
      "required": [
        "subfeatureIds",
        "journeyIds",
        "flowIds",
        "requirementIds"
      ],
      "additionalProperties": false,
      "properties": {
        "subfeatureIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "journeyIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "flowIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "requirementIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "relatedFeatureIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "openQuestions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "generatedRefs": {
      "type": "object",
      "additionalProperties": true
    },
    "db": {
      "type": "object",
      "additionalProperties": true
    },
    "custom": {
      "$ref": "shared-definitions.schema.json#/$defs/custom"
    },
    "confirmationBaseline": {
      "$ref": "shared-definitions.schema.json#/$defs/confirmationBaseline"
    },
    "uxQualityAssessment": {
      "$ref": "shared-definitions.schema.json#/$defs/uxQualityAssessment"
    },
    "runtimeAlignment": {
      "$ref": "shared-definitions.schema.json#/$defs/runtimeAlignment"
    },
    "behaviorRelations": {
      "$ref": "shared-definitions.schema.json#/$defs/behaviorRelations"
    }
  }
}
