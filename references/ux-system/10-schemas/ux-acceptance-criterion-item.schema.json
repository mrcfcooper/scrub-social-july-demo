{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tgn.local/schemas/ux/ux-acceptance-criterion-item.schema.json",
  "title": "TGN UX Acceptance Criterion Item",
  "type": "object",
  "required": [
    "schema",
    "itemType",
    "id",
    "title",
    "mode",
    "status",
    "authority",
    "confidence",
    "owner",
    "scope",
    "criterion",
    "relationships",
    "confirmationBaseline"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "type": "string",
      "const": "tgn.ux-acceptance-criterion.v1"
    },
    "itemType": {
      "type": "string",
      "const": "uxAcceptanceCriterion"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "$ref": "shared-definitions.schema.json#/$defs/mode"
    },
    "status": {
      "$ref": "shared-definitions.schema.json#/$defs/status"
    },
    "authority": {
      "$ref": "shared-definitions.schema.json#/$defs/authority"
    },
    "confidence": {
      "$ref": "shared-definitions.schema.json#/$defs/confidence"
    },
    "owner": {
      "$ref": "shared-definitions.schema.json#/$defs/owner"
    },
    "scope": {
      "$ref": "shared-definitions.schema.json#/$defs/scope"
    },
    "criterion": {
      "type": "object",
      "required": [
        "given",
        "when",
        "then",
        "and",
        "proofPriority",
        "automationExpectation",
        "manualProofAllowed",
        "failureMeaning"
      ],
      "additionalProperties": false,
      "properties": {
        "given": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "when": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "then": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "and": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "proofPriority": {
          "type": "string",
          "enum": [
            "critical",
            "high",
            "normal",
            "low"
          ]
        },
        "automationExpectation": {
          "type": "string",
          "enum": [
            "automated-required",
            "automated-preferred",
            "manual-allowed",
            "manual-only"
          ]
        },
        "manualProofAllowed": {
          "type": "boolean"
        },
        "failureMeaning": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "relationships": {
      "type": "object",
      "required": [
        "requirementIds",
        "scenarioIds",
        "subflowIds"
      ],
      "additionalProperties": false,
      "properties": {
        "requirementIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "scenarioIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "subflowIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "testRefs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "openQuestions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "generatedRefs": {
      "type": "object",
      "additionalProperties": true
    },
    "db": {
      "type": "object",
      "additionalProperties": true
    },
    "custom": {
      "$ref": "shared-definitions.schema.json#/$defs/custom"
    },
    "confirmationBaseline": {
      "$ref": "shared-definitions.schema.json#/$defs/confirmationBaseline"
    },
    "uxQualityAssessment": {
      "$ref": "shared-definitions.schema.json#/$defs/uxQualityAssessment"
    },
    "runtimeAlignment": {
      "$ref": "shared-definitions.schema.json#/$defs/runtimeAlignment"
    },
    "behaviorRelations": {
      "$ref": "shared-definitions.schema.json#/$defs/behaviorRelations"
    }
  }
}
